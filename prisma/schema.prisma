generator client {
  provider               = "prisma-client"
  output                 = "../src/generated/prisma"
  moduleFormat           = "esm"
  generatedFileExtension = "ts"
  importFileExtension    = "ts"
}

datasource db {
  provider = "sqlite"
}

enum UserRole {
  USER
  AUTHOR
  MODERATOR
  ADMIN
  SUPERADMIN
}

enum AccountStatus {
  ACTIVE
  RESTRICTED
  BANNED
}

enum PostStatus {
  DRAFT
  PENDING
  PUBLISHED
  REJECTED
  ARCHIVED
}

model User {
  id                       Int                 @id @default(autoincrement())
  email                    String              @unique
  password                 String
  name                     String
  slug                     String              @unique
  city                     String?
  phone                    String?
  showContacts             Boolean             @default(false)
  avatar                   String?
  role                     UserRole            @default(USER)
  emailVerified            DateTime?
  verificationToken        String?
  verificationTokenExpires DateTime?
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt
  // Статус аккаунта
  status                   AccountStatus       @default(ACTIVE)
  // Блокировка (BANNED)
  banReason                String?
  bannedAt                 DateTime?
  bannedBy                 Int?
  // Ограничение (RESTRICTED)
  restrictedReason         String?
  restrictedAt             DateTime?
  restrictedBy             Int?
  // Связи
  posts                    Post[]              @relation("AuthoredPosts")
  events                   Event[]             @relation("AuthoredEvents")
  eventRegistrations       EventRegistration[]
  notifications            Notification[]
  moderationLogs           ModerationLog[]
  moderatedPosts           Post[]              @relation("ModeratedPosts")
  moderatedEvents          Event[]             @relation("ModeratedEvents")
  banLogs                  UserBanLog[]        @relation("BanLogs")
  banActions               UserBanLog[]        @relation("BanActions")

  @@index([slug])
}

enum EventFormat {
  ONLINE
  OFFLINE
}

enum EventStatus {
  DRAFT
  PENDING
  PUBLISHED
  REJECTED
  ARCHIVED
}

model Event {
  id              Int                 @id @default(autoincrement())
  title           String
  slug            String              @unique
  description     String?
  format          EventFormat
  city            String?
  location        String?
  startDate       DateTime
  endDate         DateTime
  coverImage      String?
  status          EventStatus         @default(DRAFT)
  rejectionReason String?
  author          User                @relation("AuthoredEvents", fields: [authorId], references: [id])
  authorId        Int
  moderatedAt     DateTime?
  moderatedBy     Int?
  moderator       User?               @relation("ModeratedEvents", fields: [moderatedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  registrations   EventRegistration[]
  created         DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  moderationLogs  ModerationLog[]

  @@index([slug])
}

model EventRegistration {
  id           Int      @id @default(autoincrement())
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId      Int
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       Int
  registeredAt DateTime @default(now())

  @@unique([eventId, userId])
}

enum PostCategory {
  NEWS
  ARTICLE
}

model Post {
  id              Int             @id @default(autoincrement())
  title           String
  slug            String          @unique
  content         String?
  coverImage      String?
  created         DateTime        @default(now())
  status          PostStatus      @default(DRAFT)
  category        PostCategory    @default(NEWS)
  rejectionReason String?
  author          User            @relation("AuthoredPosts", fields: [authorId], references: [id])
  authorId        Int
  moderatedAt     DateTime?
  moderatedBy     Int?
  moderator       User?           @relation("ModeratedPosts", fields: [moderatedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  moderationLogs  ModerationLog[]

  @@index([slug])
}

model Notification {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  title     String
  message   String
  isRead    Boolean  @default(false)
  type      String
  createdAt DateTime @default(now())
}

model ModerationLog {
  id          Int      @id @default(autoincrement())
  post        Post?    @relation(fields: [postId], references: [id])
  postId      Int?
  event       Event?   @relation(fields: [eventId], references: [id])
  eventId     Int?
  moderator   User     @relation(fields: [moderatorId], references: [id])
  moderatorId Int
  oldStatus   String?
  newStatus   String?
  reason      String?
  createdAt   DateTime @default(now())
}

model UserBanLog {
  id            Int       @id @default(autoincrement())
  user          User      @relation("BanLogs", fields: [userId], references: [id])
  userId        Int
  action        BanAction // RESTRICTED, UNRESTRICTED, BANNED, UNBANNED
  reason        String?
  moderator     User      @relation("BanActions", fields: [moderatorId], references: [id])
  moderatorId   Int
  previousValue String? // Предыдущее значение статуса
  createdAt     DateTime  @default(now())

  @@index([userId])
}

enum BanAction {
  RESTRICTED
  UNRESTRICTED
  BANNED
  UNBANNED
}
