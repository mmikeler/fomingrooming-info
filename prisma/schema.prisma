generator client {
  provider               = "prisma-client"
  output                 = "../src/generated/prisma"
  moduleFormat           = "esm"
  generatedFileExtension = "ts"
  importFileExtension    = "ts"
}

datasource db {
  provider = "sqlite"
}

enum UserRole {
  USER
  AUTHOR
  MODERATOR
  ADMIN
  SUPERADMIN
}

enum PostStatus {
  DRAFT
  PENDING
  PUBLISHED
  REJECTED
  ARCHIVED
}

model User {
  id             Int             @id @default(autoincrement())
  email          String          @unique
  password       String
  name           String
  role           UserRole        @default(USER)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  posts          Post[]          @relation("AuthoredPosts")
  notifications  Notification[]
  moderationLogs ModerationLog[]
  moderatedPosts Post[]          @relation("ModeratedPosts")
}

model Post {
  id              Int             @id @default(autoincrement())
  title           String
  slug            String          @unique
  content         String?
  created         DateTime        @default(now())
  status          PostStatus      @default(DRAFT)
  rejectionReason String?
  author          User            @relation("AuthoredPosts", fields: [authorId], references: [id])
  authorId        Int
  moderatedAt     DateTime?
  moderatedBy     Int?
  moderator       User?           @relation("ModeratedPosts", fields: [moderatedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  moderationLogs  ModerationLog[]

  @@index([slug])
}

model Notification {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  title     String
  message   String
  isRead    Boolean  @default(false)
  type      String
  createdAt DateTime @default(now())
}

model ModerationLog {
  id          Int        @id @default(autoincrement())
  post        Post       @relation(fields: [postId], references: [id])
  postId      Int
  moderator   User       @relation(fields: [moderatorId], references: [id])
  moderatorId Int
  oldStatus   PostStatus
  newStatus   PostStatus
  reason      String?
  createdAt   DateTime   @default(now())
}
